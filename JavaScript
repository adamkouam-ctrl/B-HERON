<script src="https://unpkg.com/@formspree/ajax@1" defer></script>

<script>
  // ... (Leave your language switching and window scroll scripts intact here) ...

  // Initialize Formspree Engine
  window.formspree = window.formspree || function () { (formspree.q = formspree.q || []).push(arguments); };

  // Connect your live Enquiry Form to Formspree
  formspree('initForm', {
    formElement: '#enquiryForm',
    formId: 'mjgzaelz',
    onSuccess: function(formElement) {
      // Pull form choices to pass them dynamically into your premium notification toast alert
      const name = document.getElementById('firstName').value || 'there';
      const selectedService = document.getElementById('service').value || 'service';
      
      // Fire your custom luxury notification popup safely
      triggerNotification(`Thank you, ${name}. Your request for the ${selectedService} has been securely transmitted. Our concierge desk will contact you within 2 hours.`);
      
      // Blank out fields safely after submission finishes
      formElement.reset();
    }
  });
</script>

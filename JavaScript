// Functional Form Assignment: Service Booking Request Form
  document.getElementById('enquiryForm').addEventListener('submit', function(e) {
    e.preventDefault(); // Prevents the page from redirecting
    const form = this;
    const name = document.getElementById('firstName').value;
    const model = document.getElementById('vehicle').value;
    
    const formData = new FormData(form);

    fetch(form.action, {
      method: form.method,
      body: formData,
      headers: {
        'Accept': 'application/json'
      }
    })
    .then(response => {
      if (response.ok) {
        // Triggers your luxury toast alert seamlessly
        triggerNotification(`Thank you, ${name}. Your request for the ${model} has been securely transmitted. Our concierge desk will contact you within 2 hours.`);
        form.reset();
      } else {
        triggerNotification("There was an issue transmitting your request. Please try again.");
      }
    })
    .catch(error => {
      triggerNotification("Network connection error. Please try again.");
    });
  });

